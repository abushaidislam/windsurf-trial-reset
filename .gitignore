# Windsurf Trial Reset Tool - GitIgnore

# Build and release artifacts
releases/
dist/
bin/

# PowerShell specific
*.ps1~
*.ps1.backup

# Windows executables and libraries
*.exe
*.exe~
*.dll
*.sys
*.com

# Test and temporary files
*.tmp
*.temp
*.log
*.bak
*~

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# OS specific files
.DS_Store
Thumbs.db
desktop.ini

# Backup files (should not be committed)
*.backup
backups/

# Configuration and sensitive data
config.local.*
secrets.*
*.key
*.pem

# Test directories
test-results/
coverage/

# Node.js (if any)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Go specific (legacy)
go.sum
go/
.cache/
*.test
*.out
coverage.txt
*.syso

# Legacy directories
.cunzhi*/
.sanshu*/
docs/